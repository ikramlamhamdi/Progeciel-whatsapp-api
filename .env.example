# Copier ce fichier en ".env" (à la racine du projet, à côté de manage.py)
# et remplir les vraies valeurs. Ce fichier .env.example, lui, est versionné
# et ne doit JAMAIS contenir de vrais secrets.

# ==================== DJANGO ====================
SECRET_KEY=
DEBUG=True
# En prod : domaine(s) réel(s) séparés par des virgules, ex: monserveur.com,localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1
# Chaque valeur doit inclure le schéma (http:// ou https://), obligatoire depuis Django 4.0
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ==================== WHATSAPP CLOUD API (Meta) ====================
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_APP_ID=
META_GRAPH_VERSION=v23.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ==================== N8N (webhook Django -> n8n) ====================
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# ==================== OUTILS TIERS (pas lus directement par Django) ====================
# Ces clés ne sont pas consommées par le code Django : elles servent aux
# credentials n8n (nœuds Gemini / Groq) et à la config ngrok en local.
# Gardées ici pour centraliser tous les secrets du projet au même endroit.
GEMINI_API_KEY=
GROQ_API_KEY=
NGROK_HOST=
